# ============================================================
#  OMNICEE — Environment Variables
#  Copy to .env and fill in your values
# ============================================================

# ── Telegram ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_IDS=123456789,987654321    # comma-separated
TELEGRAM_ALLOWED_USER_IDS=123456789       # comma-separated Mini App allowlist

# Alternate Mini App auth: a shared-secret token, checked BEFORE Telegram
# initData (falls through to Telegram if unset/absent/wrong). Lets you (or
# anyone you share this with) open the dashboard in a plain browser outside
# Telegram. Leave unset to disable this path entirely — Telegram auth still
# works exactly as before either way.
APP_ACCESS_TOKEN=

# ── Data Feeds ────────────────────────────────────────────
TWELVE_DATA_API_KEY=your_twelvedata_key
FINNHUB_API_KEY=your_finnhub_key
BINANCE_API_KEY=your_binance_key        # optional, read-only for kline history
BINANCE_API_SECRET=your_binance_secret  # optional

# ── External Data Sources (Institutional-Grade) ────────────
# Myfxbook - Economic Calendar & Community Sentiment
MYFXBOOK_EMAIL=your_myfxbook_email
MYFXBOOK_PASSWORD=your_myfxbook_password

# Parse.bot API for OpenInsider (SEC Form 4 Insider Trading)
PARSE_API_KEY=your_parse_bot_api_key

# ── Symbols to trade ──────────────────────────────────────
# Comma-separated list
SYMBOLS=BTCUSDT,ETHUSDT,XAUUSD,EURUSD,GBPUSD,USOIL,USDJPY,XAGUSD
# ── Timeframes ────────────────────────────────────────────
# Comma-separated: H1,H4,D1 recommended
TIMEFRAMES=15m, H1,H4,D1

# ── Risk settings ─────────────────────────────────────────
RISK_PCT_PER_TRADE=1.0         # 1% per trade
MAX_DAILY_LOSS_PCT=3.0         # pause trading after 3% daily loss
MAX_DRAWDOWN_PCT=10.0          # hard stop after 10% drawdown
ACCOUNT_BALANCE=10000          # your account size in USD

# ── Signal thresholds ─────────────────────────────────────
MIN_SIGNAL_SCORE=75            # minimum confluence score to fire
REQUIRE_KILLZONE=false         # only fire signals in London/NY sessions

# ── MongoDB Atlas ─────────────────────────────────────────
# URL-encode special characters in passwords. Example: @ becomes %40
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=omnicee_db
MONGODB_MAX_POOL=5
MONGODB_SIGNAL_TTL_DAYS=45
MONGODB_TELEMETRY_TTL_DAYS=7

# ── AI Advisor (agentic layer, optional) ───────────────────
# Advisory-only LLM review of signals that already passed every deterministic
# filter — can recommend SKIP/REDUCE_SIZE with a plain-English reason, never
# touches execution or risk parameters directly. Leave ANTHROPIC_API_KEY unset
# to disable entirely (fails open — pipeline runs exactly as it did before).
# This key is billed separately from any Claude.ai subscription — see
# https://console.anthropic.com for key creation and usage-based pricing.
ANTHROPIC_API_KEY=
ANTHROPIC_ADVISOR_MODEL=claude-sonnet-5   # or claude-haiku-4-5-20251001 for lower cost/latency

# ── System ────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info                 # debug | info | warn | error
PORT=3001
WS_PORT=3001                   # fallback if PORT is unset — keep in sync with PORT
API_RATE_LIMIT_PER_MIN=120
CORS_ORIGIN=
REDIS_URL=                     # optional — enables MemoryManager's Redis layer if set
DATABASE_URL=                  # optional — alt Postgres connection string, distinct from MONGODB_URI

# ── MT5 EA bridge ─────────────────────────────────────────
# Shared secret the MT5 EA sends as X-EA-Secret (or ?secret=) when polling
# /api/ea/signals. LEAVE UNSET = that endpoint is open to anyone with the URL.
EA_SECRET=

# ── Telegram (optional extras) ─────────────────────────────
GRADE_A_CHANNEL_ID=            # optional separate channel for Grade-A-only alerts

# ── Institutional validation engine tuning (all optional, sane defaults) ───
BAYES_PRIOR=0.50
BAYES_MIN_POSTERIOR=0.52
MC_SIMULATIONS=5000
MC_MIN_WIN_PROB=0.55
MC_MIN_EXPECTED_R=0.3
STAT_MIN_TESTS=5
STAT_SIGNIFICANCE=0.05
WF_MIN_SAMPLES=20
WF_MIN_WFE=0.35
ENSEMBLE_MIN_CONFIDENCE=60

# ── Adaptive learning engine tuning (optional, sane defaults) ─────────────
LEARNING_MIN_SAMPLES=6
LEARNING_WARN_WIN_RATE=0.42
LEARNING_BLOCK_WIN_RATE=0.28
LEARNING_CACHE_TTL_MS=300000

# ── Feed caching (optional, sane defaults) ─────────────────
FINNHUB_CACHE_MS=300000
