# ══════════════════════════════════════════════════════════════════════
#  OMNICEE — Environment Variables
#  Copy to .env for local dev, or paste into Render's dashboard for deploy.
#  Everything in QUICK START actually matters. Everything after it has a
#  safe default — the system runs fine with it left blank, just with that
#  one feature disabled (and a log line telling you so on boot).
# ══════════════════════════════════════════════════════════════════════


# ─── 1. QUICK START (fill these in to get a working deploy) ────────────

# From @BotFather on Telegram (/newbot)
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Your numeric Telegram user ID, from @userinfobot. Comma-separated for more than one.
TELEGRAM_CHAT_IDS=123456789

# Alternate Mini App login: a shared-secret you make up yourself, checked
# BEFORE Telegram auth. Lets you open the dashboard in a normal browser —
# on your phone, laptop, wherever — not just inside Telegram. Leave blank
# to disable this path; Telegram auth still works exactly the same either way.
APP_ACCESS_TOKEN=

# Shared secret for the MT5 Expert Advisor bridge (/api/ea/signals). Make
# up any random string. LEAVE BLANK = that endpoint has no auth at all —
# don't deploy to production without setting this.
EA_SECRET=

# Your account size in USD — used for position-size math.
ACCOUNT_BALANCE=10000


# ─── 2. Data feeds ───────────────────────────────────────────────────
# Binance and Bybit need no key (public market data). Everything else
# below needs a free-tier key to enable that specific feed; leave blank
# to skip it, the system just runs without that data source.

TWELVE_DATA_API_KEY=              # forex/commodities (EURUSD, XAUUSD, etc) — twelvedata.com
FINNHUB_API_KEY=                  # real news + company data, feeds sentiment scoring — finnhub.io
BINANCE_API_KEY=                  # optional, read-only, only needed for extended kline history
BINANCE_API_SECRET=

MYFXBOOK_EMAIL=                   # economic calendar + community sentiment (your MyFXBook login)
MYFXBOOK_PASSWORD=

PARSE_API_KEY=                    # optional — improves OpenInsider (SEC Form 4) reliability


# ─── 3. Trading configuration ───────────────────────────────────────

SYMBOLS=BTCUSDT,ETHUSDT,XAUUSD,EURUSD,GBPUSD,USOIL,USDJPY,XAGUSD

# Comma-separated. Must match the codebase's own timeframe codes exactly:
# M1,M5,M15,M30,H1,H2,H4,H6,H8,H12,D1,W1 (uppercase — lowercase like "15m"
# will not match anything and that timeframe will silently do nothing).
TIMEFRAMES=M15,H1,H4,D1

RISK_PCT_PER_TRADE=1.0            # % of account risked per trade
MAX_DAILY_LOSS_PCT=3.0            # pause trading after this much lost in a day
MAX_DRAWDOWN_PCT=10.0             # hard stop after this much drawdown from peak
MIN_SIGNAL_SCORE=75               # minimum confluence score (0-100) required to fire a signal
REQUIRE_KILLZONE=false            # true = only fire signals during London/NY session overlap

DXY_SYMBOL=UUP                    # FIX: was DXY — TwelveData's own indices page
                                   # ("twelvedata.com/indices") states indices data is
                                   # "coming soon", not live yet, so a literal index
                                   # symbol always fails with "symbol or figi parameter
                                   # is missing or invalid". UUP (Invesco DB US Dollar
                                   # Index Bullish Fund) is the standard ETF proxy for
                                   # the Dollar Index — tracks it closely, fully
                                   # supported as normal ETF data.
EQUITY_INDEX_SYMBOL=SPY           # FIX: was SPX500 — same TwelveData indices-not-live
                                   # issue as above. SPY (SPDR S&P 500 ETF Trust) is the
                                   # standard, extremely liquid ETF proxy for the S&P
                                   # 500 index used exactly for this purpose.


# ─── 4. Database (optional — signals still fire live without this,
#        nothing just persists across a restart) ────────────────────

# URL-encode special characters in the password (@ becomes %40, etc).
MONGODB_URI=
MONGODB_DB=omnicee_db
MONGODB_MAX_POOL=5
MONGODB_SIGNAL_TTL_DAYS=45
MONGODB_TELEMETRY_TTL_DAYS=7


# ─── 5. Telegram extras (optional) ──────────────────────────────────

TELEGRAM_ALLOWED_USER_IDS=        # comma-separated Mini App allowlist; blank = anyone with the link
GRADE_A_CHANNEL_ID=               # optional separate channel for Grade-A-only alerts


# ─── 6. AI Advisor (optional, agentic layer) ────────────────────────
# Advisory-only LLM review of signals that already passed every
# deterministic filter — can recommend SKIP/REDUCE_SIZE with a plain-
# English reason, never touches execution or risk parameters directly.
# Leave blank to disable entirely (fails open, pipeline runs exactly as
# it did before). Billed separately from any Claude.ai subscription — see
# https://console.anthropic.com for key creation and usage pricing.

ANTHROPIC_API_KEY=
ANTHROPIC_ADVISOR_MODEL=claude-sonnet-5   # or claude-haiku-4-5-20251001 for lower cost/latency


# ─── 7. Institutional engine tuning (optional — all have sane
#        defaults, only touch these if you know why) ────────────────

BAYES_PRIOR=0.50
BAYES_MIN_POSTERIOR=0.52
MC_SIMULATIONS=5000
MC_MIN_WIN_PROB=0.55
MC_MIN_EXPECTED_R=0.3
STAT_MIN_TESTS=5
STAT_SIGNIFICANCE=0.05
WF_MIN_SAMPLES=20
WF_MIN_WFE=0.35
ENSEMBLE_MIN_CONFIDENCE=60

LEARNING_MIN_SAMPLES=6
LEARNING_WARN_WIN_RATE=0.42
LEARNING_BLOCK_WIN_RATE=0.28
LEARNING_CACHE_TTL_MS=300000

FINNHUB_CACHE_MS=300000


# ─── 8. System / infrastructure (optional — defaults work fine on
#        Render; only change these for local dev or a different host) ─

NODE_ENV=production
LOG_LEVEL=info                    # debug | info | warn | error
PORT=3001
WS_PORT=3001                      # fallback if PORT is unset — keep in sync with PORT
API_RATE_LIMIT_PER_MIN=120
CORS_ORIGIN=

REDIS_URL=                        # optional — enables MemoryManager's Redis caching layer
DATABASE_URL=                     # optional — alt Postgres connection string, distinct from MONGODB_URI
